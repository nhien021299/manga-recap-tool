AI_BACKEND_HOST=127.0.0.1
AI_BACKEND_PORT=8000
AI_BACKEND_CORS_ORIGINS=http://localhost:5173
AI_BACKEND_TEMP_ROOT=.temp/jobs
AI_BACKEND_GEMINI_API_KEY=
AI_BACKEND_GEMINI_MODEL=gemini-2.5-flash
AI_BACKEND_GEMINI_API_ENDPOINT=
AI_BACKEND_GEMINI_SCRIPT_BATCH_SIZE=4
AI_BACKEND_GEMINI_IDENTITY_EXPERIMENT_ENABLED=true
AI_BACKEND_GEMINI_IDENTITY_OCR_MIN_CONFIDENCE=0.70
AI_BACKEND_GEMINI_IDENTITY_OCR_MAX_TEXT_LINES=8
AI_BACKEND_GEMINI_MAX_CONCURRENT_REQUESTS=1
AI_BACKEND_GEMINI_MIN_REQUEST_INTERVAL_MS=750
AI_BACKEND_GEMINI_RETRY_ATTEMPTS=4
AI_BACKEND_GEMINI_RETRY_BASE_DELAY_MS=2000
AI_BACKEND_GEMINI_RETRY_MAX_DELAY_MS=15000
AI_BACKEND_GEMINI_COOLDOWN_ON_429_MS=20000

# Text generation provider used for narration / script stage
AI_BACKEND_TEXT_PROVIDER=ollama
AI_BACKEND_TEXT_MODEL=gemma3
AI_BACKEND_TEXT_BASE_URL=http://localhost:11434

# Vision provider used for panel understanding / caption stage
AI_BACKEND_VISION_PROVIDER=ollama_vision
AI_BACKEND_VISION_MODEL=qwen2.5vl:7b
AI_BACKEND_VISION_BASE_URL=http://localhost:11434

# Vision timeout / retry controls for long local inference runs
AI_BACKEND_VISION_TIMEOUT_SECONDS=120
AI_BACKEND_VISION_TIMEOUT_RETRIES=2
AI_BACKEND_VISION_RETRY_DELAY_SECONDS=5

# Resize images before sending them to the local vision model.
# Aspect ratio is preserved; these are max bounds, not forced output size.
AI_BACKEND_VISION_MAX_WIDTH=512
AI_BACKEND_VISION_MAX_HEIGHT=1024

# OCR grounding toggle
AI_BACKEND_OCR_ENABLED=true
AI_BACKEND_OCR_MIN_CONFIDENCE=0.55
AI_BACKEND_OCR_MAX_TEXT_LINES=20
AI_BACKEND_OCR_PREFER_SFX=true
AI_BACKEND_OCR_DEBUG_SAVE_JSON=false

AI_BACKEND_LLAMA_CPP_BASE_URL=http://127.0.0.1:8080/v1

# TTS provider used for local voice generation
AI_BACKEND_TTS_PROVIDER=vieneu
AI_BACKEND_TTS_RUNTIME=auto
AI_BACKEND_TTS_WARM_ON_STARTUP=false
AI_BACKEND_TTS_SMOKE_TEST_TEXT=
AI_BACKEND_TTS_MAX_CONCURRENT_JOBS=1
AI_BACKEND_TTS_VIENEU_MODEL_ID=pnnbao-ump/VieNeu-TTS-0.3B
AI_BACKEND_TTS_VIENEU_TEMPERATURE=1.0
AI_BACKEND_TTS_VIENEU_VOICE_KEY=voice_default
AI_BACKEND_TTS_VIENEU_VOICE_ROOT=.models/vieneu-voices

# Safer local defaults for Ollama caption stability
AI_BACKEND_CAPTION_CHUNK_SIZE=1
AI_BACKEND_CAPTION_MAX_TOKENS=512

AI_BACKEND_SCRIPT_CHUNK_SIZE=10

# Retry invalid script chunks instead of silently degrading output
AI_BACKEND_SCRIPT_GENERATION_RETRIES=2
AI_BACKEND_SCRIPT_RETRY_DELAY_SECONDS=3
